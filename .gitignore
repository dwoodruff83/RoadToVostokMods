# --- Game decompile / reference (sensitive: do not push) ---
reference/

# --- Personal save backups ---
save_backups/

# --- Third-party / large binary tools ---
tools/Godot/
tools/GDRE_tools/
tools/GDRE_tools-*.zip
tools/DepotDownloader/

# --- Steam-fetched / decompile scratch (regenerated each backfill) ---
tools/_versions/

# --- ModWorkshop stats history + comment archive (operational data; regenerable from API) ---
tools/mw_stats.csv
tools/mw_stats_state.json
tools/mw_comments_archive.json

# --- Mod-impact diff reports (contain decompiled source diffs — keep local only) ---
diff_reports/*
!diff_reports/README.md

# --- Mod build outputs ---
**/*.vmz

# --- Godot import cache (regenerated on import; only needed inside .vmz) ---
**/.godot/

# --- Python bytecode (from running tools/*.py locally) ---
**/__pycache__/
*.pyc

# --- MCM runtime config (per-user) ---
mods/*/MCM/

# --- Blender autosaves ---
*.blend1

# --- Junction-mount setup backups (created when temporarily junctioning
# a mod folder against the decompiled project for in-editor work). ---
*.bak.preJunction

# --- Agent / IDE / OS junk ---
.claude/
.vscode/*
# Whitelist shared editor config (no secrets, no per-machine paths).
# .vscode/settings.json stays ignored — it contains absolute editor paths.
!.vscode/mcp.json
*.tmp
*.log
Thumbs.db
.DS_Store
